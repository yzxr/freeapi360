{
  "name": "derouter-clone",
  "version": "0.1.0",
  "private": true,
  "description": "DeRouter 复刻项目 - AI 算力共享网络平台",
  "scripts": {
    "dev": "concurrently \"npm run dev:provider\" \"npm run dev:consumer\"",
    "dev:provider": "npm run dev --workspace=apps/provider",
    "dev:consumer": "npm run dev --workspace=apps/consumer",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
